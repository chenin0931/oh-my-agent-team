# Mobile production env — committed so external users can build a personal
# iPhone copy of OhMyAgentTeam against the same backend as ohmyagentteam.com on web.
# Loaded by the `*:prod` scripts via dotenv-cli (see package.json).
EXPO_PUBLIC_API_URL=https://api.ohmyagentteam.com
EXPO_PUBLIC_WEB_URL=https://ohmyagentteam.com
